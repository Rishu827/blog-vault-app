# ── Site ──────────────────────────────────────────────────────────────────────
# Full URL of the deployed site (no trailing slash). Used for canonical URLs,
# sitemap, RSS feed, and OG image absolute URLs.
SITE_URL=https://your-blog.vercel.app

# ── Giscus Comments ───────────────────────────────────────────────────────────
# 1. Create a public GitHub repo and enable Discussions.
# 2. Install the Giscus app: https://github.com/apps/giscus
# 3. Create a "Blog Comments" category in GitHub Discussions.
# 4. Visit https://giscus.app to get your repo ID and category ID.

# Format: owner/repo
GISCUS_REPO=owner/repo

# Repo ID from giscus.app (starts with R_)
GISCUS_REPO_ID=

# Discussion category name (must match exactly)
GISCUS_CATEGORY=Blog Comments

# Category ID from giscus.app (starts with DIC_)
GISCUS_CATEGORY_ID=
