---
import { getCollection } from 'astro:content';
import BaseLayout from '../components/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { calculateReadingTime } from '../utils/readingTime';

const isDev = import.meta.env.DEV;
const siteUrl = (import.meta.env.SITE_URL as string | undefined)?.replace(/\/$/, '') ?? 'https://rishabh-writes.vercel.app';
const feedUrl = `${siteUrl}/rss.xml`;
const feedlyUrl = `https://feedly.com/i/subscription/feed/${encodeURIComponent(feedUrl)}`;

const allPosts = await getCollection('blog', ({ data }) => {
  if (isDev) return true;
  return !data.draft && data.publishDate <= new Date();
});

const posts = allPosts
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 5);
---

<BaseLayout
  title="RishabhWrites | Home"
  description="A personal developer blog about software engineering, architecture, and tooling."
>
  <!-- Hero -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 pt-16 pb-12">
    <div class="flex flex-col gap-4">
      <h1 class="text-4xl sm:text-5xl font-bold leading-tight" style="color: var(--color-heading);">
        Hi, I'm <span style="color: var(--color-accent);">Rishabh Singhal</span>
      </h1>
      <p class="text-lg max-w-2xl" style="color: var(--color-text-muted);">
        I write about software engineering, system design, and the tools I use every day.
        Topics include TypeScript, Rust, Go, DevOps, and more.
      </p>
      <div class="flex flex-wrap gap-3 mt-2">
        <a
          href="/blog"
          class="px-5 py-2.5 rounded-lg text-sm font-semibold transition-opacity hover:opacity-80"
          style="background-color: var(--color-accent); color: #fff;"
        >
          Read the blog →
        </a>
        <!-- RSS subscribe button — opens Feedly with the feed pre-loaded -->
        <div class="relative" id="rss-wrapper">
          <div class="flex rounded-lg border overflow-hidden" style="border-color: var(--color-border);">
            <a
              href={feedlyUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 px-4 py-2.5 text-sm font-medium transition-colors hover:opacity-80"
              style="color: var(--color-text);"
              aria-label="Subscribe via RSS — opens in Feedly"
            >
              <!-- RSS icon -->
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="color: var(--color-accent);">
                <circle cx="6.18" cy="17.82" r="2.18"/>
                <path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"/>
              </svg>
              Subscribe via RSS
            </a>
            <!-- Divider -->
            <div style="width:1px; background-color: var(--color-border);"></div>
            <!-- Copy URL button -->
            <button
              id="rss-copy-btn"
              data-feed-url={feedUrl}
              aria-label="Copy RSS feed URL"
              title="Copy feed URL"
              class="px-3 py-2.5 text-sm transition-colors hover:opacity-80 focus-visible:outline-none focus-visible:ring-2"
              style="color: var(--color-text-muted); --tw-ring-color: var(--color-accent);"
            >
              <svg id="rss-icon-copy" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
              </svg>
              <svg id="rss-icon-check" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden" style="color: var(--color-accent);">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </button>
          </div>
          <!-- Copied tooltip -->
          <span
            id="rss-copied"
            class="hidden absolute left-1/2 -bottom-8 -translate-x-1/2 text-xs px-2 py-1 rounded whitespace-nowrap"
            style="background-color: var(--color-bg-secondary); color: var(--color-text-muted); border: 1px solid var(--color-border);"
            role="status"
            aria-live="polite"
          >
            Copied!
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Recent posts -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 pb-16">
    <h2 class="text-xl font-bold mb-6" style="color: var(--color-heading);">
      Recent Posts
    </h2>

    {posts.length === 0 ? (
      <p style="color: var(--color-text-muted);">No posts yet. Check back soon!</p>
    ) : (
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-1">
        {posts.map((post) => {
          const slug = post.data.slug ?? post.slug;
          const readingTime = calculateReadingTime(post.body);
          return (
            <PostCard
              title={post.data.title}
              slug={slug}
              description={post.data.description}
              publishDate={post.data.publishDate}
              readingTime={readingTime}
              tags={post.data.tags}
              coverImage={post.data.coverImage}
              coverImageAlt={post.data.coverImageAlt}
              draft={post.data.draft}
            />
          );
        })}
      </div>
    )}

    {allPosts.length > 5 && (
      <div class="mt-8 text-center">
        <a
          href="/blog"
          class="inline-block px-5 py-2.5 rounded-lg border text-sm font-medium transition-colors hover:opacity-80"
          style="border-color: var(--color-border); color: var(--color-text);"
        >
          View all posts →
        </a>
      </div>
    )}
  </section>
<script>
  const btn = document.getElementById('rss-copy-btn');
  const iconCopy = document.getElementById('rss-icon-copy');
  const iconCheck = document.getElementById('rss-icon-check');
  const tooltip = document.getElementById('rss-copied');

  btn?.addEventListener('click', async () => {
    const feedUrl = document.getElementById('rss-copy-btn')?.dataset.feedUrl ?? `${window.location.origin}/rss.xml`;
    await navigator.clipboard.writeText(feedUrl);
    iconCopy?.classList.add('hidden');
    iconCheck?.classList.remove('hidden');
    tooltip?.classList.remove('hidden');
    setTimeout(() => {
      iconCopy?.classList.remove('hidden');
      iconCheck?.classList.add('hidden');
      tooltip?.classList.add('hidden');
    }, 2000);
  });
</script>
</BaseLayout>
