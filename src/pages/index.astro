---
import { getCollection } from 'astro:content';
import BaseLayout from '../components/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { calculateReadingTime } from '../utils/readingTime';

const isDev = import.meta.env.DEV;

const allPosts = await getCollection('blog', ({ data }) => {
  if (isDev) return true;
  return !data.draft && data.publishDate <= new Date();
});

const posts = allPosts
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 5);
---

<BaseLayout
  title="DevBlog | Home"
  description="A personal developer blog about software engineering, architecture, and tooling."
>
  <!-- Hero -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 pt-16 pb-12">
    <div class="flex flex-col gap-4">
      <h1 class="text-4xl sm:text-5xl font-bold leading-tight" style="color: var(--color-heading);">
        Hi, I'm <span style="color: var(--color-accent);">Dev Author</span>
      </h1>
      <p class="text-lg max-w-2xl" style="color: var(--color-text-muted);">
        I write about software engineering, system design, and the tools I use every day.
        Topics include TypeScript, Rust, Go, DevOps, and more.
      </p>
      <div class="flex flex-wrap gap-3 mt-2">
        <a
          href="/blog"
          class="px-5 py-2.5 rounded-lg text-sm font-semibold transition-opacity hover:opacity-80"
          style="background-color: var(--color-accent); color: #fff;"
        >
          Read the blog →
        </a>
        <a
          href="/rss.xml"
          class="px-5 py-2.5 rounded-lg border text-sm font-medium transition-colors hover:opacity-80"
          style="border-color: var(--color-border); color: var(--color-text);"
        >
          Subscribe via RSS
        </a>
      </div>
    </div>
  </section>

  <!-- Recent posts -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 pb-16">
    <h2 class="text-xl font-bold mb-6" style="color: var(--color-heading);">
      Recent Posts
    </h2>

    {posts.length === 0 ? (
      <p style="color: var(--color-text-muted);">No posts yet. Check back soon!</p>
    ) : (
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-1">
        {posts.map((post) => {
          const slug = post.data.slug ?? post.slug;
          const readingTime = calculateReadingTime(post.body);
          return (
            <PostCard
              title={post.data.title}
              slug={slug}
              description={post.data.description}
              publishDate={post.data.publishDate}
              readingTime={readingTime}
              tags={post.data.tags}
              coverImage={post.data.coverImage}
              coverImageAlt={post.data.coverImageAlt}
              draft={post.data.draft}
            />
          );
        })}
      </div>
    )}

    {allPosts.length > 5 && (
      <div class="mt-8 text-center">
        <a
          href="/blog"
          class="inline-block px-5 py-2.5 rounded-lg border text-sm font-medium transition-colors hover:opacity-80"
          style="border-color: var(--color-border); color: var(--color-text);"
        >
          View all posts →
        </a>
      </div>
    )}
  </section>
</BaseLayout>
