---
export interface Props {
  tag: string;
  class?: string;
}

const { tag, class: className = '' } = Astro.props;
---

<a
  href={`/tags/${tag}`}
  class={`inline-block text-xs font-medium px-2.5 py-0.5 rounded no-underline transition-opacity hover:opacity-75 ${className}`}
  style="background-color: var(--color-bg-secondary); color: var(--color-text-muted); border: 1px solid var(--color-border);"
>
  #{tag}
</a>
