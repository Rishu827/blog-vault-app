---
import BaseLayout from './BaseLayout.astro';
import TagBadge from './TagBadge.astro';
import TableOfContents from './TableOfContents.tsx';
import GiscusComments from './GiscusComments.astro';
import CopyCodeButton from './CopyCodeButton.tsx';
import ReadingProgress from './ReadingProgress.tsx';
import SelectionComment from './SelectionComment.tsx';
import type { Heading } from './TableOfContents.tsx';

export interface Props {
  title: string;
  description: string;
  publishDate: Date;
  updatedDate?: Date | null;
  author: string;
  tags: string[];
  readingTime: number;
  coverImage?: string | null;
  coverImageAlt?: string;
  canonicalURL?: string | null;
  headings: Heading[];
  draft?: boolean;
}

const {
  title,
  description,
  publishDate,
  updatedDate,
  author,
  tags,
  readingTime,
  coverImage,
  coverImageAlt,
  canonicalURL,
  headings,
  draft = false,
} = Astro.props;

const giscusRepo = import.meta.env.GISCUS_REPO ?? '';
const giscusCategory = import.meta.env.GISCUS_CATEGORY ?? 'Blog Comments';

const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdated = updatedDate
  ? updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: publishDate.toISOString(),
  dateModified: (updatedDate ?? publishDate).toISOString(),
  author: { '@type': 'Person', name: author },
  image: coverImage ?? undefined,
  url: Astro.url.href,
  mainEntityOfPage: { '@type': 'WebPage', '@id': Astro.url.href },
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalURL={canonicalURL}
  ogImage={coverImage}
  ogType="article"
  publishDate={publishDate}
  updatedDate={updatedDate}
  tags={tags}
  author={author}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <!-- Reading progress bar -->
  <ReadingProgress client:load />

  <div class="max-w-[90rem] mx-auto px-4 sm:px-6 py-10">
    <div class="xl:grid xl:grid-cols-[1fr_220px] xl:gap-16 max-w-3xl xl:max-w-none mx-auto xl:mx-0">

      <!-- Article -->
      <article aria-labelledby="post-title">

        {coverImage && (
          <img
            src={coverImage}
            alt={coverImageAlt ?? ''}
            class="w-full rounded-xl mb-8 object-cover max-h-80"
            loading="eager"
            decoding="async"
            width="900"
            height="320"
          />
        )}

        <header class="mb-10">
          {draft && (
            <span class="inline-block mb-3 text-xs font-bold px-2.5 py-1 rounded bg-yellow-200 text-yellow-900 dark:bg-yellow-800 dark:text-yellow-200">
              DRAFT — Not published
            </span>
          )}

          <h1 id="post-title" class="text-3xl sm:text-4xl font-bold leading-tight mb-5" style="color: var(--color-heading);">
            {title}
          </h1>

          <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm mb-5 pb-5 border-b" style="color: var(--color-text-muted); border-color: var(--color-border);">
            <span class="font-medium" style="color: var(--color-text);">{author}</span>
            <span aria-hidden="true">·</span>
            <time datetime={publishDate.toISOString()}>{formattedDate}</time>
            <span aria-hidden="true">·</span>
            <span>{readingTime} min read</span>
            {formattedUpdated && (
              <>
                <span aria-hidden="true">·</span>
                <span>Updated <time datetime={updatedDate!.toISOString()}>{formattedUpdated}</time></span>
              </>
            )}
          </div>

          {tags.length > 0 && (
            <div class="flex flex-wrap gap-2" role="list" aria-label="Post tags">
              {tags.map((tag) => (
                <div role="listitem"><TagBadge tag={tag} /></div>
              ))}
            </div>
          )}
        </header>

        <!-- Article body — id used by ReadingProgress and SelectionComment -->
        <div
          id="article-body"
          class="relative prose prose-slate dark:prose-invert max-w-none
            prose-p:leading-8 prose-p:text-[1.0625rem]
            prose-headings:scroll-mt-[calc(var(--navbar-height)+1.5rem)]
            prose-headings:font-bold
            prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4
            prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
            prose-li:leading-7
            prose-blockquote:not-italic prose-blockquote:border-l-4
            selection:bg-blue-200 dark:selection:bg-blue-800 selection:text-inherit"
        >
          <slot />

          <!-- Highlight-to-comment tooltip (absolute positioned inside article-body) -->
          {giscusRepo && (
            <SelectionComment
              repo={giscusRepo}
              category={giscusCategory}
              pageTitle={title}
              pageUrl={Astro.url.href}
              client:load
            />
          )}
        </div>

        <CopyCodeButton client:visible />

        <GiscusComments />
      </article>

      <!-- Desktop ToC sidebar (only shown ≥ xl) -->
      <aside aria-label="Table of contents" class="hidden xl:block">
        <TableOfContents headings={headings} client:idle />
      </aside>
    </div>
  </div>
</BaseLayout>
