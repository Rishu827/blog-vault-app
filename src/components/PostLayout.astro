---
import BaseLayout from './BaseLayout.astro';
import TagBadge from './TagBadge.astro';
import TableOfContents from './TableOfContents.tsx';
import GiscusComments from './GiscusComments.astro';
import CopyCodeButton from './CopyCodeButton.tsx';
import type { Heading } from './TableOfContents.tsx';

export interface Props {
  title: string;
  description: string;
  publishDate: Date;
  updatedDate?: Date | null;
  author: string;
  tags: string[];
  readingTime: number;
  coverImage?: string | null;
  coverImageAlt?: string;
  canonicalURL?: string | null;
  headings: Heading[];
  draft?: boolean;
}

const {
  title,
  description,
  publishDate,
  updatedDate,
  author,
  tags,
  readingTime,
  coverImage,
  coverImageAlt,
  canonicalURL,
  headings,
  draft = false,
} = Astro.props;

const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdated = updatedDate
  ? updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;

// JSON-LD BlogPosting schema
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: publishDate.toISOString(),
  dateModified: (updatedDate ?? publishDate).toISOString(),
  author: {
    '@type': 'Person',
    name: author,
  },
  image: coverImage ?? undefined,
  url: Astro.url.href,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': Astro.url.href,
  },
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalURL={canonicalURL}
  ogImage={coverImage}
  ogType="article"
  publishDate={publishDate}
  updatedDate={updatedDate}
  tags={tags}
  author={author}
>
  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <div class="max-w-[90rem] mx-auto px-4 sm:px-6 py-10">
    <div class="xl:grid xl:grid-cols-[1fr_220px] xl:gap-16 max-w-4xl xl:max-w-none mx-auto xl:mx-0">

      <!-- Article -->
      <article aria-labelledby="post-title">

        <!-- Cover image -->
        {coverImage && (
          <img
            src={coverImage}
            alt={coverImageAlt ?? ''}
            class="w-full rounded-xl mb-8 object-cover max-h-80"
            loading="eager"
            decoding="async"
            width="900"
            height="320"
          />
        )}

        <!-- Header -->
        <header class="mb-8">
          {draft && (
            <span class="inline-block mb-3 text-xs font-bold px-2.5 py-1 rounded bg-yellow-200 text-yellow-900 dark:bg-yellow-800 dark:text-yellow-200">
              DRAFT — Not published
            </span>
          )}

          <h1 id="post-title" class="text-3xl sm:text-4xl font-bold leading-tight mb-4" style="color: var(--color-heading);">
            {title}
          </h1>

          <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm mb-4" style="color: var(--color-text-muted);">
            <span>{author}</span>
            <span aria-hidden="true">·</span>
            <time datetime={publishDate.toISOString()}>{formattedDate}</time>
            <span aria-hidden="true">·</span>
            <span>{readingTime} min read</span>
            {formattedUpdated && (
              <>
                <span aria-hidden="true">·</span>
                <span>Updated <time datetime={updatedDate!.toISOString()}>{formattedUpdated}</time></span>
              </>
            )}
          </div>

          {tags.length > 0 && (
            <div class="flex flex-wrap gap-2" role="list" aria-label="Post tags">
              {tags.map((tag) => (
                <div role="listitem">
                  <TagBadge tag={tag} />
                </div>
              ))}
            </div>
          )}
        </header>

        <!-- Mobile ToC (rendered inside article, above body) -->
        <TableOfContents headings={headings} client:idle />

        <!-- MDX body -->
        <div class="prose prose-slate dark:prose-invert max-w-none prose-headings:scroll-mt-[calc(var(--navbar-height)+1rem)]">
          <slot />
        </div>

        <!-- Activate copy buttons for code blocks -->
        <CopyCodeButton client:visible />

        <!-- Comments -->
        <GiscusComments />
      </article>

      <!-- Desktop ToC sidebar -->
      <aside aria-label="Table of contents" class="hidden xl:block">
        <TableOfContents headings={headings} client:idle />
      </aside>
    </div>
  </div>
</BaseLayout>
