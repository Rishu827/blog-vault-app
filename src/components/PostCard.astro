---
import TagBadge from './TagBadge.astro';

export interface Props {
  title: string;
  slug: string;
  description: string;
  publishDate: Date;
  readingTime: number;
  tags: string[];
  coverImage?: string | null;
  coverImageAlt?: string;
  draft?: boolean;
}

const {
  title,
  slug,
  description,
  publishDate,
  readingTime,
  tags,
  coverImage,
  coverImageAlt,
  draft = false,
} = Astro.props;

const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article
  class="group flex flex-col sm:flex-row gap-5 py-7 border-b"
  style="border-color: var(--color-border);"
>
  {coverImage && (
    <a href={`/blog/${slug}`} tabindex="-1" aria-hidden="true" class="sm:flex-shrink-0">
      <img
        src={coverImage}
        alt={coverImageAlt ?? ''}
        class="w-full sm:w-36 h-28 object-cover rounded"
        loading="lazy"
        decoding="async"
        width="144"
        height="112"
        style="border: 1px solid var(--color-border);"
      />
    </a>
  )}

  <div class="flex-1 flex flex-col gap-2">
    <div class="flex items-center gap-2 flex-wrap">
      {draft && (
        <span class="text-xs font-bold px-2 py-0.5 rounded" style="background-color: #fef3c7; color: #92400e;">
          DRAFT
        </span>
      )}
      {tags.slice(0, 3).map((tag) => <TagBadge tag={tag} />)}
    </div>

    <h2 class="text-xl font-bold leading-snug m-0" style="font-family: 'Playfair Display', Georgia, serif;">
      <a
        href={`/blog/${slug}`}
        class="hover:underline"
        style="color: var(--color-heading);"
      >
        {title}
      </a>
    </h2>

    <p class="text-sm leading-relaxed m-0" style="color: var(--color-text-muted);">
      {description}
    </p>

    <footer class="flex items-center gap-3 text-xs mt-auto pt-1" style="color: var(--color-text-muted);">
      <time datetime={publishDate.toISOString()}>{formattedDate}</time>
      <span aria-hidden="true" style="color: var(--color-ornament);">·</span>
      <span>{readingTime} min read</span>
      <a
        href={`/blog/${slug}`}
        class="ml-auto text-xs font-medium hover:underline"
        style="color: var(--color-accent);"
        aria-label={`Read ${title}`}
      >
        Read →
      </a>
    </footer>
  </div>
</article>
